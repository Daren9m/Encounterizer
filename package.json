{
  "name": "encounterizer",
  "version": "1.0.0",
  "private": true,
  "description": "Free D&D 5.5e toolkit — encounter prep, live battle tools, and searchable SRD references",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:bestiary": "tsx scripts/import-bestiary.ts",
    "import:srd": "tsx scripts/import-srd-content.ts",
    "srd:check": "tsx scripts/srd-md/audit.ts --check",
    "generate:flavor": "tsx scripts/generate-flavor.ts",
    "flavor:check": "tsx scripts/flavor/audit.ts --check",
    "import:spells": "tsx scripts/import-spells.ts",
    "make:runic-font": "node scripts/make-runic-font.mjs",
    "visuals:sync": "tsx scripts/enrich-bestiary-visuals.ts",
    "visuals:check": "tsx scripts/enrich-bestiary-visuals.ts --check",
    "visuals:seed-pilot": "tsx scripts/seed-pilot-visuals.ts",
    "visuals:seed-production": "tsx scripts/seed-production-visuals.ts",
    "visuals:export-review": "tsx scripts/export-visual-review.ts",
    "visuals:audit": "tsx scripts/audit-visual-descriptions.ts",
    "visuals:audit-images": "tsx scripts/audit-monster-images.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Daren9m/Encounterizer.git"
  },
  "homepage": "https://github.com/Daren9m/Encounterizer",
  "bugs": {
    "url": "https://github.com/Daren9m/Encounterizer/issues"
  },
  "keywords": [
    "dnd",
    "5e",
    "encounter",
    "dungeons-and-dragons",
    "tabletop",
    "srd",
    "dm-tools"
  ],
  "author": "Daren9m",
  "license": "MIT",
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.5.19",
    "subset-font": "^2.5.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0",
    "vitest": "^3.2.7"
  }
}
